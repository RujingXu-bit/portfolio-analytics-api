# Local-only development configuration. Copy to .env and change values as needed.
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://portfolio:portfolio_local_only@localhost:55432/portfolio
TEST_DATABASE_URL=postgresql+asyncpg://portfolio_test:portfolio_test_local_only@localhost:55433/portfolio_test
REDIS_URL=redis://localhost:6379/0
DEFAULT_BASE_CURRENCY=USD

POSTGRES_DB=portfolio
POSTGRES_PASSWORD=portfolio_local_only
POSTGRES_PORT=55432
POSTGRES_USER=portfolio

TEST_POSTGRES_DB=portfolio_test
TEST_POSTGRES_PASSWORD=portfolio_test_local_only
TEST_POSTGRES_PORT=55433
TEST_POSTGRES_USER=portfolio_test

REDIS_PORT=6379
